TZ_NAME=Asia/Shanghai
START_DATE=2026-07-05

# Common values:
# QQ/163: SMTP_SECURITY=ssl, SMTP_PORT=465
# Gmail/Outlook: SMTP_SECURITY=starttls, SMTP_PORT=587
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-authorization-code

MAIL_FROM=your-email@example.com
MAIL_FROM_NAME=多元思维模型
MAIL_TO=receiver@example.com
SUBJECT_PREFIX=多元思维模型

# TrendRadar-compatible alternatives.
# If these already exist in Gordoncee/TrendRadar, you can reuse them instead
# of creating MAIL_FROM / SMTP_PASSWORD / MAIL_TO again.
EMAIL_FROM=your-outlook@example.com
EMAIL_PASSWORD=your-outlook-app-password
EMAIL_TO=receiver@example.com
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=
